{
  "name": "GDS-15",
  "description": "Geriatric Depression Scale - 15 item version. Screens for depression in older adults (60+).",
  "estimated_minutes": 5,
  "questions": [
    {"id": "gds1", "text": "Are you basically satisfied with your life?", "subscale": "depression", "options": [{"value": 0, "label": "Yes"}, {"value": 1, "label": "No"}]},
    {"id": "gds2", "text": "Have you dropped many of your activities and interests?", "subscale": "depression", "options": [{"value": 1, "label": "Yes"}, {"value": 0, "label": "No"}]},
    {"id": "gds3", "text": "Do you feel that your life is empty?", "subscale": "depression", "options": [{"value": 1, "label": "Yes"}, {"value": 0, "label": "No"}]},
    {"id": "gds4", "text": "Do you often get bored?", "subscale": "depression", "options": [{"value": 1, "label": "Yes"}, {"value": 0, "label": "No"}]},
    {"id": "gds5", "text": "Are you in good spirits most of the time?", "subscale": "depression", "options": [{"value": 0, "label": "Yes"}, {"value": 1, "label": "No"}]},
    {"id": "gds6", "text": "Are you afraid that something bad is going to happen to you?", "subscale": "depression", "options": [{"value": 1, "label": "Yes"}, {"value": 0, "label": "No"}]},
    {"id": "gds7", "text": "Do you feel happy most of the time?", "subscale": "depression", "options": [{"value": 0, "label": "Yes"}, {"value": 1, "label": "No"}]},
    {"id": "gds8", "text": "Do you often feel helpless?", "subscale": "depression", "options": [{"value": 1, "label": "Yes"}, {"value": 0, "label": "No"}]},
    {"id": "gds9", "text": "Do you prefer to stay at home rather than going out and doing new things?", "subscale": "depression", "options": [{"value": 1, "label": "Yes"}, {"value": 0, "label": "No"}]},
    {"id": "gds10", "text": "Do you feel you have more problems with memory than most?", "subscale": "cognitive", "options": [{"value": 1, "label": "Yes"}, {"value": 0, "label": "No"}]},
    {"id": "gds11", "text": "Do you think it is wonderful to be alive now?", "subscale": "depression", "options": [{"value": 0, "label": "Yes"}, {"value": 1, "label": "No"}]},
    {"id": "gds12", "text": "Do you feel pretty worthless the way you are now?", "subscale": "depression", "options": [{"value": 1, "label": "Yes"}, {"value": 0, "label": "No"}]},
    {"id": "gds13", "text": "Do you feel full of energy?", "subscale": "depression", "options": [{"value": 0, "label": "Yes"}, {"value": 1, "label": "No"}]},
    {"id": "gds14", "text": "Do you feel that your situation is hopeless?", "subscale": "depression", "options": [{"value": 1, "label": "Yes"}, {"value": 0, "label": "No"}]},
    {"id": "gds15", "text": "Do you think that most people are better off than you are?", "subscale": "depression", "options": [{"value": 1, "label": "Yes"}, {"value": 0, "label": "No"}]}
  ]
}
