# ─── Database ───
DATABASE_URL=postgresql+asyncpg://manoveil:manoveil@localhost:5432/manoveil
REDIS_URL=redis://localhost:6379/0

# ─── Auth ───
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI/ML ───
HF_MODEL_ID=distilbert-base-uncased-finetuned-sst-2-english
OPENAI_API_KEY=sk-...
SHAP_ENABLED=true

# ─── Blockchain / Federated Learning ───
FABRIC_PEER_ENDPOINT=grpc://localhost:7051
FABRIC_ORDERER_ENDPOINT=grpc://localhost:7050
FABRIC_CHANNEL_NAME=manoveil-channel
FABRIC_CHAINCODE_NAME=manoveil-gradient
FL_AGGREGATOR_URL=http://localhost:8081
DP_EPSILON=0.8
HE_KEY_BITS=2048
IPFS_NODE_URL=http://localhost:5001

# ─── AWS (future) ───
AWS_REGION=ap-south-1

# ─── App ───
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
